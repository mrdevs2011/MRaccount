{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/modules/:path+",
      "destination": "/modules/:path+"
    },
    {
      "source": "/CSS/:path+",
      "destination": "/CSS/:path+"
    },
    {
      "source": "/console",
      "destination": "/console/index.html"
    },
    {
      "source": "/console/:path+",
      "destination": "/console/:path+"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
