rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Foydalanuvchi profili:
    // - Hamma o'qiy oladi (boshqa ilovalar ID bo'yicha lookup qilishi uchun)
    // - Faqat o'zi yoza oladi
    match /users/{uid} {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
